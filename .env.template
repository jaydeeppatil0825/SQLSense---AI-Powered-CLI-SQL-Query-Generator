# ─────────────────────────────────────────────────────────────
# AI SQL Query Generator — environment variable template
# Copy this file to .env and fill in real values.
# NEVER commit .env (with real values) to version control.
# ─────────────────────────────────────────────────────────────

# MySQL hostname or IP address of your database server
DB_HOST=your_mysql_host

# MySQL username with SELECT privileges on DB_NAME
DB_USER=your_mysql_user

# MySQL password for DB_USER
DB_PASSWORD=your_mysql_password

# Name of the target MySQL database to inspect and query
DB_NAME=your_database_name

# AI backend to use for SQL generation.
# Active CLI workflow uses local Ollama only.
LLM_BACKEND=local

# Ollama model name to use when LLM_BACKEND=local.
# Default is "llama3". Other options: "mistral", "codellama", etc.
# Requires Ollama running locally: https://ollama.com
LOCAL_MODEL=llama3
LOCAL_API_URL=http://localhost:11434
LOCAL_TIMEOUT=120

# Legacy NVIDIA configuration is disabled in the CLI workflow.
# NVIDIA is intentionally disabled from the active CLI workflow for now.

# Enable AI-powered business insights after SQL execution.
# true  = use the configured local Ollama backend to generate insights
#         after every query result; falls back to rule-based if AI fails.
# false = use rule-based insights only (fast, no network call required).
ENABLE_AI_INSIGHTS=true

# Print the full AI system prompt to the terminal before sending it.
# Useful for debugging why a query or insight came out wrong.
# true = print prompt | false = silent (default)
DEBUG_PROMPT=false

# Enable verbose debug logging to logs/app.log.
# true  = log all operations including debug-level details
# false = log only info, warning, and error levels (default)
DEBUG_MODE=false
